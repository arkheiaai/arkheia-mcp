# Arkheia Enterprise Proxy -- required environment variables
# Copy this file to understand what you need. Fill values into your secrets
# manager (Doppler, AWS SSM, Windows Credential Manager, etc.).
# NEVER commit a .env file with real values.

# Registry authentication (required for profile updates from registry.arkheia.ai)
# Leave empty to run with local profiles only.
ARKHEIA_API_KEY=

# Optional: override profile directory (useful for local development)
# Example: ARKHEIA_PROFILES_DIR=C:/arkheia-proxy/profiles
ARKHEIA_PROFILES_DIR=

# Optional: override audit log path
# ARKHEIA_AUDIT_LOG=/var/log/arkheia/audit.jsonl

# Optional: path to arkheia-proxy.yaml config file
# ARKHEIA_CONFIG=/etc/arkheia/arkheia-proxy.yaml

# Optional: set to "production" to disable /docs endpoint
# ARKHEIA_ENV=production
